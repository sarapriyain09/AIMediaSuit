generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ModuleType {
  VOICE
  SCRIPT
  PODCAST
  VIDEO
  AVATAR
}

enum GenerationStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum VoiceType {
  alloy
  ash
  ballad
  coral
  echo
  sage
  shimmer
}

enum ScriptGoal {
  social
  ad
  youtube
  email
  sales
}

enum ScriptTone {
  professional
  friendly
  bold
  educational
  storytelling
}

enum ScriptLength {
  short
  medium
  long
}

model MediaGeneration {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @db.Uuid
  moduleType ModuleType
  title      String
  inputText  String
  voice      VoiceType
  speed      Decimal          @db.Decimal(3, 2)
  duration   Int?
  outputUrl  String?
  status     GenerationStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([userId, moduleType, createdAt])
}

model ScriptGeneration {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @db.Uuid
  title        String
  prompt       String
  outputText   String
  goal         ScriptGoal
  tone         ScriptTone
  length       ScriptLength
  audience     String
  callToAction String?
  status       GenerationStatus @default(COMPLETED)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([userId, createdAt])
}
